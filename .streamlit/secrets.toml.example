# Copy this file to .streamlit/secrets.toml for local testing, or paste these values into the Streamlit Community Cloud secrets manager when deploying.

LLM_PROVIDER = "groq"
GROQ_API_KEY = "your_api_key_here"
MODEL_NAME = "llama-3.3-70b-versatile"
MAX_OUTPUT_TOKENS = 4096
MAX_RETRIES = 3
CHROMA_PERSIST_DIR = "./memory/chroma_store"
EXPORT_DIR = "./output/exports"
MAX_FILE_SIZE_MB = 50
DEBUG = false
